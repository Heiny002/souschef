// Config.xcconfig — base build configuration (committed to the repo).
//
// Provides a safe default for every setting the project references, then
// OPTIONALLY pulls in Secrets.xcconfig for developer-local values (API keys).
// The `#include?` form means a missing Secrets.xcconfig is not an error: the
// project builds without it and the LLM-fallback features simply stay inert.
//
// To add your key: copy Secrets.example.xcconfig → Secrets.xcconfig (or run
// ./Scripts/bootstrap.sh) and fill in ANTHROPIC_API_KEY. Secrets.xcconfig is
// gitignored so real keys never reach the repo.

// Default so $(ANTHROPIC_API_KEY) always resolves. Overridden by Secrets.xcconfig
// when present — this must appear BEFORE the include (last assignment wins).
ANTHROPIC_API_KEY =

// Optional HTTPS base URL of the transcript/search backend (e.g. a deployed
// FastAPI instance). Empty means: release builds skip those layers; DEBUG
// falls back to http://localhost:8000 for local development.
RECIPE_BACKEND_URL =

// --- Code signing (developer-local) ---
// These live here, NOT in the tracked project file, so Xcode never rewrites
// project.pbxproj when you sign for a device — which is what used to make every
// `git pull` conflict. The committed defaults keep CI and fresh clones building
// for the Simulator with no team. To run on a physical device, put your Team ID
// (and a unique bundle id if com.souschef.app is taken) in Signing.xcconfig — it
// is gitignored. See Signing.example.xcconfig, or run ./Scripts/bootstrap.sh.
//
// Set BEFORE the include so Signing.xcconfig's values win (last assignment wins).
PRODUCT_BUNDLE_IDENTIFIER = com.souschef.app
DEVELOPMENT_TEAM =
CODE_SIGN_STYLE = Automatic

#include? "Secrets.xcconfig"
#include? "Signing.xcconfig"
